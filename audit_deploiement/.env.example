# ============================================================
#  NOVADEMY_DEPLOIEMENT — .env.example (back-end)
#  Gabarit à dupliquer en `backend/.env` (jamais versionné).
#
#  Auteur  : KAMGA MAFFO Rosalie Manuella
#  Module  : Déploiement de projet informatique (Diginova)
#  Séance 2 — Bloc 4
#
#  CONSIGNE :
#    1. Copier ce fichier en `backend/.env`
#    2. Remplir les valeurs locales
#    3. NE JAMAIS committer `backend/.env`
# ============================================================

# --- SERVEUR ---
# Port d'écoute du back-end Express.
# Module Déploiement : 5001 (au lieu de 5000 du projet original).
PORT=5001

# Origine front-end autorisée par CORS.
# Local : http://localhost:5174
# Production : https://novademy.fr (ou domaine équivalent)
FRONT_ORIGIN=http://localhost:5174

# Environnement Node : development | test | production
NODE_ENV=development

# --- BASE DE DONNEES MYSQL ---
# Hôte de la base.
#   - Local hors Docker  : localhost
#   - Docker Compose     : db   (nom du service dans docker-compose.yml)
#   - Production         : adresse de votre serveur MySQL managé
DB_HOST=localhost

# Port MySQL (par défaut 3306).
DB_PORT=3306

# Utilisateur MySQL.
# Production : créer un utilisateur dédié non-root avec uniquement les privilèges
# nécessaires sur la base novademy (SELECT, INSERT, UPDATE, DELETE, EXECUTE).
DB_USER=novademy_app

# Mot de passe MySQL.
# DEV : ne jamais utiliser une valeur triviale.
# PROD : 24+ caractères, généré avec un gestionnaire de mots de passe.
DB_PASSWORD=__changez_moi__

# Nom de la base.
DB_NAME=novademy

# --- AUTHENTIFICATION JWT ---
# Secret de signature des tokens JWT (HS256).
# Génération recommandée (64 octets en hex) :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# IMPORTANT : valeur différente entre dev, staging et prod. Jamais commitée.
JWT_SECRET=__changez_moi__

# Durée de validité du token (format zeit/ms : "7d", "12h", "30m").
JWT_EXPIRES_IN=7d

# --- UPLOAD FICHIERS (Multer) ---
# Dossier de destination des photos / justificatifs.
UPLOAD_DIR=./uploads

# Taille maximale d'un upload (en octets). 5 Mo = 5242880.
UPLOAD_MAX_SIZE=5242880

# --- RATE LIMITING ---
# Fenêtre de comptage (en minutes) pour express-rate-limit.
RATE_LIMIT_WINDOW_MIN=15

# Nombre max de requêtes / fenêtre, route générique.
RATE_LIMIT_MAX_GENERAL=200

# Nombre max de requêtes / fenêtre, routes d'authentification.
RATE_LIMIT_MAX_AUTH=10

# --- E-MAIL (optionnel, pour reset password en production) ---
# Si vide, les e-mails sont écrits en console (mode dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@novademy.fr

# --- DIVERS ---
# Niveau de logs : error | warn | info | debug
LOG_LEVEL=info
